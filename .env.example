# Wiredash
WIREDASH_SECRET=
WIREDASH_PROJECT_ID=

# Adresseingaben
GEOAPIFY_KEY=
MAPS_STAMM_OFFLINE_RADIUS_KM=5
MAPS_MEMBER_OFFLINE_RADIUS_KM=0.5

# Optional lokal genutzte Zusatzwerte
OPEN_AI_KEY=
APPSTORE_ID=

# Pull Notifications
PULL_NOTIFICATIONS_URL=https://raw.githubusercontent.com/ORG/REPO/branch/notifications.json
PULL_NOTIFICATIONS_MIN_FETCH_INTERVAL_HOURS=1

# Remote-Version fuer App-Update-Hinweise
APP_UPDATE_URL=https://digital-scouts.github.io/dpsg-nami-app/version.json
APP_UPDATE_MIN_FETCH_INTERVAL_HOURS=12
APP_UPDATE_FETCH_TIMEOUT_SECONDS=5

# Hitobito OAuth (Entwicklung / spaeter produktiv pro Umgebung ersetzen)
HITOBITO_BASE_URL=https://demo.hitobito.com
HITOBITO_OAUTH_CLIENT_ID=
HITOBITO_OAUTH_CLIENT_SECRET=
HITOBITO_OAUTH_REDIRECT_URI=de.jlange.nami.app:/oauth/callback

# Hitobito Datenhaltung
HITOBITO_DATA_MAX_AGE_DAYS=90
HITOBITO_REFRESH_INTERVAL_HOURS=24
HITOBITO_APP_LOCK_TIMEOUT_SECONDS=60
