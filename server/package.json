{
    "name": "nami-statistics-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Statistics server scaffold for the DPSG NaMi app.",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "dev:db": "docker-compose up -d mongodb",
        "dev:db:down": "docker-compose down",
        "build": "tsc --project tsconfig.json",
        "start": "node dist/index.js",
        "docker:prod:up": "docker-compose -f docker-compose.prod.yml up --build -d",
        "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
        "typecheck": "tsc --noEmit --project tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "dotenv": "^17.2.3",
        "fastify": "^5.6.1",
        "mongodb": "^6.17.0",
        "pino-pretty": "^13.1.2",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@types/node": "^24.6.0",
        "tsx": "^4.20.6",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    }
}